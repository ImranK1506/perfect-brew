---
// Footer component inspired by Storeplate design
---

<footer class="bg-gradient-to-br from-neutral-50 to-neutral-100 border-t border-neutral-200">
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center space-x-2 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center shadow-lg shadow-primary-500/20">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M10 2v2"/>
              <path d="M14 2v2"/>
              <path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/>
              <path d="M6 2v2"/>
            </svg>
          </div>
          <span class="text-xl font-black text-neutral-900">Perfect Brew</span>
        </div>
        <p class="text-neutral-600 max-w-md leading-relaxed font-medium">
          AI-powered coffee brewing recommendations that help you discover the perfect cup every time. 
          Tailored to your beans and equipment for optimal flavor extraction.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-neutral-900 font-bold mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">Home</a></li>
          <li><a href="/coffee-reference" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">Brewing Fundamentals</a></li>
          <li><a href="/faq" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">FAQ</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-neutral-900 font-bold mb-4">Support</h3>
        <ul class="space-y-2.5">
          <li><a href="/faq" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">FAQ</a></li>
          <li><a href="#" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">Contact</a></li>
          <li><a href="#" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">Privacy Policy</a></li>
          <li><a href="#" class="text-neutral-600 hover:text-primary-600 transition-colors font-medium">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-neutral-200 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-neutral-500 text-sm font-medium">
        © 2024 Perfect Brew. All rights reserved.
      </p>
      <div class="flex items-center space-x-4 mt-4 md:mt-0">
        <span class="text-neutral-500 text-sm font-medium">Powered by AI</span>
        <div class="flex space-x-2">
          <div class="w-2 h-2 bg-primary-500 rounded-full animate-pulse"></div>
          <div class="w-2 h-2 bg-secondary-500 rounded-full animate-pulse" style="animation-delay: 0.2s"></div>
          <div class="w-2 h-2 bg-primary-400 rounded-full animate-pulse" style="animation-delay: 0.4s"></div>
        </div>
      </div>
    </div>
  </div>
</footer>