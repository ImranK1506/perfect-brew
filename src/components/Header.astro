---
// Modern Header component
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-neutral-100">
  <div class="container mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 group">
        <div class="w-11 h-11 bg-gradient-to-br from-primary-500 via-primary-600 to-primary-700 rounded-2xl flex items-center justify-center shadow-lg shadow-primary-500/30 group-hover:shadow-xl group-hover:shadow-primary-500/40 transition-all duration-300 group-hover:scale-105 group-hover:rotate-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M10 2v2"/>
            <path d="M14 2v2"/>
            <path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/>
            <path d="M6 2v2"/>
          </svg>
        </div>
        <span class="text-2xl font-black bg-gradient-to-r from-neutral-900 via-neutral-800 to-neutral-900 bg-clip-text text-transparent">Perfect Brew</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class="px-5 py-2.5 text-sm font-semibold text-neutral-700 hover:text-neutral-900 hover:bg-neutral-50 rounded-full transition-all duration-200">
          Home
        </a>
        <a href="/coffee-reference" class="px-5 py-2.5 text-sm font-semibold text-neutral-700 hover:text-neutral-900 hover:bg-neutral-50 rounded-full transition-all duration-200">
          Brewing Fundamentals
        </a>
        <a href="/faq" class="px-5 py-2.5 text-sm font-semibold text-neutral-700 hover:text-neutral-900 hover:bg-neutral-50 rounded-full transition-all duration-200">
          FAQ
        </a>
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center">
        <a href="/#recommendation-form" class="group px-7 py-3 bg-gradient-to-r from-primary-500 to-primary-600 hover:from-primary-600 hover:to-primary-700 text-white text-sm font-bold rounded-full transition-all duration-300 shadow-lg shadow-primary-500/30 hover:shadow-xl hover:shadow-primary-500/40 hover:-translate-y-0.5">
          <span class="flex items-center gap-2">
            Get Started
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </span>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-button" class="md:hidden p-2.5 text-neutral-700 hover:text-neutral-900 hover:bg-neutral-50 rounded-xl transition-all duration-200">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-100 bg-white/95 backdrop-blur-xl">
    <div class="container mx-auto px-6 py-6 space-y-2">
      <a href="/" class="block px-5 py-3 text-neutral-700 hover:text-neutral-900 font-semibold rounded-xl hover:bg-neutral-50 transition-all duration-200">
        Home
      </a>
      <a href="/coffee-reference" class="block px-5 py-3 text-neutral-700 hover:text-neutral-900 font-semibold rounded-xl hover:bg-neutral-50 transition-all duration-200">
        Brewing Fundamentals
      </a>
      <a href="/faq" class="block px-5 py-3 text-neutral-700 hover:text-neutral-900 font-semibold rounded-xl hover:bg-neutral-50 transition-all duration-200">
        FAQ
      </a>
      <div class="pt-4">
        <a href="/#recommendation-form" class="flex items-center justify-center gap-2 px-7 py-3.5 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold rounded-full shadow-lg shadow-primary-500/30 transition-all duration-300">
          Get Started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>